# Application
APP_NAME=AI-Agent-Tutorial
APP_ENV=development
HOST=0.0.0.0
PORT=8000
# Local dev: SQLite (default). Production: Supabase Postgres connection string.
DATABASE_URL=sqlite:///./data/app.db
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
CHROMA_DIR=./data/chroma

# LLM provider: mock | ollama | gemini | openai
# mock = no API key, deterministic answers for REST/LangChain learning
# ollama = local Docker (see deploy/ollama-setup.md) — Render 雲端無法使用本機 Ollama
# gemini = free cloud LLM for Render (see deploy/free-llm-cloud.md)
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# 本機 python src/run.py + Docker Ollama：
OLLAMA_BASE_URL=http://localhost:11434
# Docker Compose 內 API 連 Ollama：
# OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# WebHook signing secret (optional; empty disables signature header)
WEBHOOK_SECRET=change-me-in-production

# Dify (Phase 3 — see deploy/dify-setup.md)
DIFY_API_BASE=http://localhost/v1
DIFY_API_KEY=
