# Application
APP_NAME=AI-Agent-Tutorial
APP_ENV=development
HOST=0.0.0.0
PORT=8000
DATABASE_URL=sqlite:///./data/app.db
CHROMA_DIR=./data/chroma

# LLM provider: mock | ollama | openai
# mock = no API key, deterministic answers for REST/LangChain learning
# ollama = local Docker (see docker-compose.yml)
# openai = production deployment (requires billing)
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# WebHook signing secret (optional; empty disables signature header)
WEBHOOK_SECRET=change-me-in-production

# Dify (Phase 3 — configure after docker compose up dify)
DIFY_API_BASE=http://localhost/v1
DIFY_API_KEY=
DIFY_APP_ID=
